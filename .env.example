# -----------------------------------------------------------------------------
# Copie para `.env`. Nunca commite segredos reais em repo público.
# Dentro do Docker Compose o host Postgres é `postgres:5432`; na máquina host
# expomos `localhost:5435` (vide docker-compose.yml).
# -----------------------------------------------------------------------------

# obrigatório — SQLAlchemy + Alembic
DATABASE_URL=postgresql+psycopg2://etl_user:etl_pass@127.0.0.1:5435/etl_db

ENVIRONMENT=development
DEBUG=false

LOG_LEVEL=INFO
LOG_DIR=logs
REPORTS_DIR=reports

CSV_INPUT_DIR=data/samples
XLSX_INPUT_DIR=data/samples

FX_API_BASE_URL=https://api.frankfurter.app
FX_CONNECT_TIMEOUT=5
FX_READ_TIMEOUT=30

# apenas para `python main.py scheduler`; se false, o comando sai sem loop
SCHEDULER_ENABLED=true
SCHEDULER_RUN_TIME=02:00

API_HOST=0.0.0.0
API_PORT=8000
