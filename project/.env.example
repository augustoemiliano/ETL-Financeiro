# App
ENVIRONMENT=development
PROJECT_NAME=Sistema Inteligente de Emissão de Minutas com IA
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security (gere chaves fortes em produção)
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Database (async app)
DATABASE_URL=postgresql+psycopg://minutas:minutas@localhost:5432/minutas_db
# Migrations (Alembic usa driver síncrono)
DATABASE_URL_SYNC=postgresql+psycopg2://minutas:minutas@localhost:5432/minutas_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI (ETAPA 4)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Paths
UPLOAD_DIR=uploads
GENERATED_DOCUMENTS_DIR=generated_documents
LOG_DIR=logs

# PDF (pdfkit precisa de wkhtmltopdf no SO — em Docker instalamos no image)
WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf
